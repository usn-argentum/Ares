[Unit]
Description=Ares rover_drive_node
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=argentum
Environment="ROS_DOMAIN_ID=42"
ExecStart=/bin/bash -c "source /opt/ros/jazzy/setup.bash && source /home/argentum/robocup_ws/install/setup.bash && ros2 run rover_drive rover_drive_node"
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
